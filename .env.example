# Copiar este ficheiro para .env.local e preencher com os valores reais.
# .env.local nunca deve ser commitado (ver .gitignore).

# Supabase (mesma base de dados do Portal)
VITE_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# URL pública deste site
VITE_SITE_URL=https://admin.bancodebensdoados.pt

# ATENÇÃO: a "secret key" (sb_secret_...) do Supabase é o equivalente à antiga
# service_role key. NUNCA deve ter o prefixo VITE_ (isso exporia-a no bundle
# do cliente) e NUNCA deve ir para este ficheiro nem para o git. Só deve ser
# usada em funções serverless (ex: Vercel Functions) e configurada
# diretamente nas variáveis de ambiente da Vercel — ver SETUP-INFRAESTRUTURA.md.
